# Copy to .env and fill in. The backend reads this via pydantic-settings.

# PostgreSQL (docker-compose default)
DATABASE_URL=postgresql+asyncpg://faithbrains:faithbrains@localhost:5433/faithbrains

# Embeddings — set one. EMBEDDING_PROVIDER: gemini | voyage | auto (auto prefers Gemini).
# Gemini key: aistudio.google.com/apikey (model gemini-embedding-2, 1024 Matryoshka dims).
#   Gemini FREE tier caps embeddings at 1000 texts/DAY — too small to embed the corpus
#   (~42K texts); fine for queries. Corpus embedding needs a billed Google project.
# Voyage note: without a payment method the account is limited to 3 requests/min +
#   10K tokens/min (slow but no daily cap — full corpus takes ~10h).
GEMINI_API_KEY=
VOYAGE_API_KEY=
EMBEDDING_PROVIDER=auto

# AI answer engine — set at least one key. AI_PROVIDER: openai | anthropic | auto
# (auto prefers OpenAI when its key is set)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_PROVIDER=auto
# Optional model overrides for the OpenAI provider
OPENAI_ANSWER_MODEL=gpt-5-mini
OPENAI_CLASSIFIER_MODEL=gpt-5-nano

# Admin views token (Milestone 4)
ADMIN_TOKEN=change-me

# Comma-separated allowed CORS origins for the frontend
CORS_ORIGINS=http://localhost:3000
